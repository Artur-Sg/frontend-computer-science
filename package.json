{
  "name": "frontend-computer-science",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.ts\" \"vite.config.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"vite.config.ts\" --fix",
    "format": "prettier -w .",
    "test:bcd": "tsx src/modules/solutions/bcd/bcd.test.ts",
    "test:bit-ops": "tsx src/modules/solutions/bit-ops/cyclic-shift.test.ts",
    "test:pixel-stream": "tsx src/modules/solutions/pixel-stream/arrays/pixel-stream.contract.test.ts",
    "bench:pixel-stream": "tsx src/modules/solutions/pixel-stream/benchmark.ts",
    "bench:pixel-stream:jitless": "node --jitless ./node_modules/.bin/tsx src/modules/solutions/pixel-stream/benchmark.ts",
    "bench:arrays": "tsx src/modules/solutions/arrays/benchmark.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.4.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vite": "^8.0.1",
    "vite-plugin-typescript-transform": "^1.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "dependencies": {
    "marked": "^12.0.2",
    "prismjs": "^1.30.0"
  }
}
