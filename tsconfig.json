{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2020"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "#app/*": ["src/app/*"],
      "#modules/*": ["src/modules/*"],
      "#core/*": ["src/core/*"],
      "#ui/*": ["src/ui/*"],
      "#styles/*": ["src/styles/*"],
      "#decorators/*": ["src/decorators/*"]
    },
    "types": ["vite/client", "node"]
  },
  "include": ["src"]
}
